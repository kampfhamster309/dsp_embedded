# Docker build cache
docker/dsp-counterpart/__pycache__/

# Test certificates (generated locally, never committed)
docker/certs/*.pem
docker/certs/*.key
docker/certs/*.crt

# Device identity credentials – generated by tools/gen_dev_certs.sh
# Private key is NEVER committed. Certificate is also excluded so the
# key and cert stay in sync (cert is signed by the key; regenerating
# the key without regenerating the cert would break the pair).
components/dsp_identity/certs/*.der
cache.md
sdkconfig.wifi

# Integration test venv
integration/.venv/
